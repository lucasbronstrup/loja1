{%- comment -%}
  ======================================================
  TRACKING: Eventos de Carrinho e Compra (Add to Cart, Purchase)
  ======================================================
  
  Este snippet injeta JavaScript que monitora eventos de carrinho
  e dispara para o dataLayer (GTM → GA4 + Google Ads + Meta Ads).

  FASE 3 (agentic-code-optimization — Optimization Agent):
  Padrão singleton para o objeto de tracking — uma única instância
  gerencia todos os eventos, evitando duplicação e race conditions.

  EVENTOS COBERTOS:
  - add_to_cart → GA4 add_to_cart + Meta AddToCart
  - remove_from_cart → GA4 remove_from_cart
  - view_cart → GA4 view_cart  
  - begin_checkout → GA4 begin_checkout + Meta InitiateCheckout
  - purchase → GA4 purchase + Google Ads conversion + Meta Purchase
  - login / sign_up → GA4 login + GA4 sign_up
  ======================================================
{%- endcomment -%}

<script>
/**
 * ShopifyTracking — Singleton de rastreamento de e-commerce
 * 
 * FASE 4 (agentic-code-optimization — HTTP client reuse via singleton):
 * Inspirado no padrão singleton identificado nas otimizações do TeaStore:
 * "HTTP client reuse via singleton pattern" → aplicamos ao objeto de tracking
 * para evitar instâncias duplicadas e garantir consistência dos eventos.
 */
(function() {
  'use strict';

  // Singleton guard
  if (window.ShopifyTracking) return;

  var currency = {{ cart.currency.iso_code | default: 'BRL' | json }};
  var shopName = {{ shop.name | json }};

  /**
   * Formata preço de centavos para decimal
   */
  function formatPrice(cents) {
    return (cents / 100).toFixed(2) * 1;
  }

  /**
   * Formata item de produto para o padrão GA4
   */
  function formatItem(item, index) {
    return {
      item_id: item.variant_id || item.id,
      item_name: item.product_title || item.title,
      item_brand: item.vendor || shopName,
      item_category: item.product_type || '',
      item_variant: item.variant_title || '',
      price: formatPrice(item.final_price || item.price),
      quantity: item.quantity || 1,
      index: index || 0,
      shopify_product_id: item.product_id,
      shopify_variant_id: item.variant_id
    };
  }

  window.ShopifyTracking = {

    /**
     * Add to Cart
     * Pode ser chamado manualmente ou via MutationObserver
     */
    addToCart: function(item, quantity) {
      quantity = quantity || 1;
      var price = formatPrice(item.price);

      window.dataLayer = window.dataLayer || [];

      // GA4 add_to_cart
      window.dataLayer.push({ ecommerce: null }); // Clear previous
      window.dataLayer.push({
        'event': 'add_to_cart',
        'ecommerce': {
          'currency': currency,
          'value': price * quantity,
          'items': [formatItem(item)]
        }
      });

      // Meta Pixel: AddToCart
      window.dataLayer.push({
        'event': 'meta_AddToCart',
        'meta_ecommerce': {
          'content_ids': [item.product_id || item.id],
          'content_name': item.product_title || item.title,
          'content_type': 'product',
          'value': price * quantity,
          'currency': currency
        }
      });
    },

    /**
     * Remove from Cart
     */
    removeFromCart: function(item) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ ecommerce: null });
      window.dataLayer.push({
        'event': 'remove_from_cart',
        'ecommerce': {
          'currency': currency,
          'value': formatPrice(item.final_price || item.price) * item.quantity,
          'items': [formatItem(item)]
        }
      });
    },

    /**
     * View Cart
     */
    viewCart: function(cart) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ ecommerce: null });
      window.dataLayer.push({
        'event': 'view_cart',
        'ecommerce': {
          'currency': currency,
          'value': formatPrice(cart.total_price),
          'items': cart.items.map(function(item, i) {
            return formatItem(item, i);
          })
        }
      });
    },

    /**
     * Begin Checkout
     * Disparar quando usuário clica em "Finalizar Compra"
     */
    beginCheckout: function(cart) {
      window.dataLayer = window.dataLayer || [];
      var value = formatPrice(cart.total_price);

      window.dataLayer.push({ ecommerce: null });
      window.dataLayer.push({
        'event': 'begin_checkout',
        'ecommerce': {
          'currency': currency,
          'value': value,
          'items': cart.items.map(function(item, i) {
            return formatItem(item, i);
          })
        }
      });

      // Meta Pixel: InitiateCheckout
      window.dataLayer.push({
        'event': 'meta_InitiateCheckout',
        'meta_ecommerce': {
          'num_items': cart.item_count,
          'value': value,
          'currency': currency
        }
      });
    }
  };

  /**
   * FASE 2 (agentic-code-optimization — Behavior Summary Agent):
   * Analisamos o fluxo de comportamento: interceptar cliques no botão
   * de adicionar ao carrinho + monitorar respostas do carrinho Shopify.
   * 
   * Interceptamos o evento nativo do tema (cart:item-added) que
   * o Prestige theme dispara após adicionar ao carrinho.
   */
  document.addEventListener('cart:item-added', function(event) {
    if (event.detail && event.detail.item) {
      window.ShopifyTracking.addToCart(event.detail.item, event.detail.item.quantity);
    }
  });

  /**
   * Monitorar clique em "Finalizar compra" para begin_checkout
   */
  document.addEventListener('click', function(event) {
    var target = event.target.closest('[href*="/checkout"], [name="checkout"], [data-checkout-button]');
    if (!target) return;

    // Fetch carrinho para pegar dados atualizados
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        if (cart.item_count > 0) {
          window.ShopifyTracking.beginCheckout(cart);
        }
      });
  }, { passive: true });

  /**
   * PERFORMANCE: usar passive listeners para scroll (Timber pattern)
   */
  if (window.performance && window.performance.mark) {
    window.performance.mark('perf:tracking-singleton-ready');
  }

})();
</script>

{%- comment -%}
  ======================================================
  GTM NOSCRIPT — Fallback para browsers sem JavaScript
  ======================================================
{%- endcomment -%}
{%- assign gtm_id = settings.gtm_container_id | default: '' -%}
{%- if gtm_id != blank -%}
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{ gtm_id }}"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
{%- endif -%}
