{"type":"footer","name":"Footer group","sections":{"text-with-icons":{"type":"text-with-icons","blocks":{"icon-1":{"type":"item","settings":{"icon":"picto-delivery-truck","icon_width":24,"mobile_icon_width":24,"title":"Frete seguro para todos brasil","content":"<p>Entregas rápidas com o máximo de cuidado e proteção.<\/p>"}},"icon-2":{"type":"item","settings":{"icon":"picto-shield","icon_width":24,"mobile_icon_width":24,"title":"Qualidade garantida","content":"<p>Todas as peças Orell possuem garantia contra defeitos de fábrica.<\/p>"}},"icon-3":{"type":"item","settings":{"icon":"picto-chat","icon_width":24,"mobile_icon_width":24,"title":"Suporte humano","content":"<p>Conte com os melhores atendentes para auxiliar você.<\/p>"}},"icon-4":{"type":"item","settings":{"icon":"picto-credit-card","icon_width":24,"mobile_icon_width":24,"title":"Pagamento seguro","content":"<p>Segurança total e transparência em cada pagamento.<\/p>"}}},"block_order":["icon-1","icon-2","icon-3","icon-4"],"settings":{"color_scheme":"","separate_section_with_border":true,"stack_on_mobile":false,"icon_color":"","text_color":"","text_alignment":"center"}},"footer":{"type":"footer","blocks":{"text_k4Xm9F":{"type":"text","settings":{"title":"Atendimento ao cliente","content":"<p>Email: sac@orellbrand.com.br<\/p><p>Whatsapp: (51) 9 9730-1716<\/p><p>Horário de atendimento: segunda a sexta-feira, das 9h00 às 18h00<\/p>","enable_follow_on_shop":true}},"newsletter":{"type":"newsletter","settings":{"title":"Newsletter","content":"<p>Receba ofertas e lançamentos exclusivos Orell Brand.<\/p>","button_background":"","button_text_color":""}},"links":{"type":"links","settings":{"menu":"main-menu","show_menu_title":true,"menu_title":""}},"links_FdiBHy":{"type":"links","settings":{"menu":"footer","show_menu_title":true,"menu_title":""}},"text":{"type":"text","settings":{"title":"Informações fiscais","content":"<p>Razão Social: Lucinara Chaves Bronstrup<br\/><br\/>CNPJ: 57.934.207\/0001-50<br\/><br\/>Endereço: Estrada Estrada Vitor Luiz Jantsch, SN, Cidade Baixa - Paverama\/RS - CEP: 95865-000<br\/><\/p>","enable_follow_on_shop":true}}},"block_order":["text_k4Xm9F","newsletter","links","links_FdiBHy","text"],"settings":{"color_scheme":"","separate_section_with_border":false,"show_social_media":true,"show_payment_icons":false,"show_powered_by_shopify":false,"show_country_selector":false,"show_country_name":true,"show_country_flag":true,"show_locale_selector":false}},"custom_liquid_eUAy7z":{"type":"custom-liquid","name":"t:sections.custom_liquid.presets.custom_liquid.name","settings":{"color_scheme":"scheme-3","separate_section_with_border":false,"remove_vertical_spacing":false,"remove_horizontal_spacing":false,"liquid":"<style>\n  \/* Estilos para organizar os selos *\/\n  .footer-trust-section {\n    display: flex;\n    justify-content: center;\n    padding: 20px 0;\n    width: 100%;\n    text-align: center;\n    overflow: hidden; \/* Evita que vaze da tela *\/\n  }\n\n  .trust-column {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    width: 100%;\n  }\n\n  .trust-title {\n    font-size: 13px;\n    font-weight: bold;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n    margin-bottom: 15px;\n    opacity: 0.8;\n  }\n\n  \/* Container dos selos de segurança *\/\n  .security-badges {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 15px;\n    flex-wrap: nowrap; \/* FORÇA A FICAR EM LINHA ÚNICA *\/\n    width: 100%;\n  }\n\n  \/* Estilo dos links clicáveis (efeito de hover) *\/\n  .security-badges a {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: transform 0.2s ease-in-out;\n    flex-shrink: 1; \/* Permite que os links encolham se a tela for muito pequena *\/\n  }\n  \n  .security-badges a:hover {\n    transform: scale(1.08); \/* Aumenta um pouquinho ao passar o mouse no PC *\/\n  }\n\n  .security-badges img {\n    height: 35px; \/* Altura padrão para alinhar todos os selos *\/\n    width: auto;\n    max-width: 100%; \/* Garante que a imagem não transborde *\/\n    object-fit: contain;\n  }\n\n  \/* Ajuste automático para telas de celular pequenas (ex: iPhone SE) *\/\n  @media (max-width: 480px) {\n    .security-badges {\n      gap: 8px; \/* Diminui o espaço entre os selos *\/\n    }\n    .security-badges img {\n      height: 24px; \/* Diminui a altura para caberem os 4 na mesma linha *\/\n    }\n  }\n<\/style>\n\n<div class=\"footer-trust-section\">\n  \n  <!-- COLUNA ÚNICA: Selos de Segurança Clicáveis -->\n  <div class=\"trust-column\">\n    <div class=\"trust-title\">Compra Segura<\/div>\n    <div class=\"security-badges\">\n      \n      <!-- Ícone Ebit apontando para verificação SSL -->\n      <a href=\"https:\/\/www.sslshopper.com\/ssl-checker.html#hostname=orellbrand.com.br\" target=\"_blank\" rel=\"noopener noreferrer\" title=\"Verificar segurança SSL\">\n        <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0945\/3777\/7336\/files\/ebit-light.png?v=1775324010\" alt=\"Selo de Segurança\" loading=\"lazy\">\n      <\/a>\n\n      <!-- Selo Google Safe Browsing -->\n      <a href=\"https:\/\/transparencyreport.google.com\/safe-browsing\/search?url=orellbrand.com.br\" target=\"_blank\" rel=\"noopener noreferrer\" title=\"Verificar segurança no Google\">\n        <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0945\/3777\/7336\/files\/google-light.png?v=1775324009\" alt=\"Google Safe Browsing\" loading=\"lazy\">\n      <\/a>\n\n      <!-- Selo Norton Safe Web -->\n      <a href=\"https:\/\/safeweb.norton.com\/report\/show?url=orellbrand.com.br\" target=\"_blank\" rel=\"noopener noreferrer\" title=\"Verificar segurança no Norton\">\n        <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0945\/3777\/7336\/files\/norton-light.png?v=1775324009\" alt=\"Norton Safe Web\" loading=\"lazy\">\n      <\/a>\n\n      <!-- Selo DMCA -->\n      <a href=\"https:\/\/www.dmca.com\/site-report\/orellbrand.com.br\" title=\"Verificar relatório DMCA\" class=\"dmca-badge\" target=\"_blank\" rel=\"noopener noreferrer\"> \n        <img src=\"https:\/\/images.dmca.com\/Badges\/dmca_protected_25_120.png?ID=ace3d9bd-34cf-4077-b757-58e0cc5dd38e\" alt=\"DMCA.com Protection Status\" loading=\"lazy\" \/>\n      <\/a>  \n      <!-- Script DMCA -->\n      <script src=\"https:\/\/images.dmca.com\/Badges\/DMCABadgeHelper.min.js\"><\/script>\n      \n    <\/div>\n    \n    <!-- Script do Futureblink -->\n    <div style=\"margin-top: 15px;\" class=\"futureblink-badge-block\" id=\"09b9a2d6-47ff-4a71-a95a-a967194482a2\"><\/div>\n  <\/div>\n\n<\/div>\n\n{%- comment -%}\n📍Frete grátis + Pix acima do preço | Box de desconto reto ao lado do preço riscado\n{%- endcomment -%}\n\n<script>\n(function() {\n  function updateBadges() {\n    \/\/ 1. Identificar se estamos em uma página de produto.\n    const mainProductSection = document.querySelector(\".shopify-section--main-product\");\n    if (!mainProductSection) return;\n\n    \/\/ 2. Encontrar o bloco de preços.\n    const priceList = mainProductSection.querySelector(\"price-list\");\n    if (!priceList) return;\n\n    \/\/ --- PARTE 1: FRETE GRÁTIS + PIX (Acima do Preço) ---\n    let freteBadge = mainProductSection.querySelector(\".custom-frete-gratis\");\n    if (!freteBadge) {\n      freteBadge = document.createElement(\"div\");\n      freteBadge.className = \"custom-frete-gratis\";\n      freteBadge.innerHTML = `\n        <svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"icon-truck\">\n          <rect x=\"1\" y=\"3\" width=\"15\" height=\"13\"><\/rect>\n          <polygon points=\"16 8 20 8 23 11 23 16 16 16 16 8\"><\/polygon>\n          <circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"><\/circle>\n          <circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"><\/circle>\n        <\/svg>\n        <span>Frete grátis + 5% OFF NO PIX<\/span>\n      `;\n      \/\/ Insere o Frete Grátis antes do bloco de preços\n      priceList.parentNode.insertBefore(freteBadge, priceList);\n    }\n\n    \/\/ --- PARTE 2: BOX DE DESCONTO (Ao lado do preço riscado) ---\n    const salePriceElement = priceList.querySelector(\"sale-price\");\n    const compareAtPriceElement = priceList.querySelector(\"compare-at-price\");\n    \n    let discountBox = mainProductSection.querySelector(\".custom-discount-box\");\n\n    if (salePriceElement && compareAtPriceElement) {\n      const parsePrice = (el) => {\n        const text = el.innerText.replace(\/[^\\d,.]\/g, \"\").replace(\",\", \".\");\n        return parseFloat(text);\n      };\n\n      const salePrice = parsePrice(salePriceElement);\n      const comparePrice = parsePrice(compareAtPriceElement);\n\n      if (comparePrice > salePrice) {\n        const discount = Math.round(((comparePrice - salePrice) \/ comparePrice) * 100);\n        \n        if (!discountBox) {\n          discountBox = document.createElement(\"span\");\n          discountBox.className = \"custom-discount-box\";\n          \/\/ Insere o Box logo após o preço riscado\n          compareAtPriceElement.parentNode.insertBefore(discountBox, compareAtPriceElement.nextSibling);\n        }\n        \n        \/\/ Atualiza o valor do desconto\n        discountBox.innerHTML = `${discount}% OFF`;\n        discountBox.style.display = \"inline-flex\"; \n      } else if (discountBox) {\n        discountBox.style.display = \"none\";\n      }\n    } else if (discountBox) {\n      discountBox.style.display = \"none\";\n    }\n  }\n\n  \/\/ Lógica para evitar múltiplas execuções\n  let isUpdating = false;\n  const runLogic = () => {\n    if (isUpdating) return;\n    isUpdating = true;\n    setTimeout(() => {\n      updateBadges();\n      isUpdating = false;\n    }, 200);\n  };\n\n  window.addEventListener(\"DOMContentLoaded\", runLogic);\n\n  const observer = new MutationObserver(runLogic);\n  observer.observe(document.body, { childList: true, subtree: true });\n\n  if (document.readyState === \"complete\" || document.readyState === \"interactive\") {\n    runLogic();\n  }\n})();\n<\/script>\n\n<style>\n  \/* Estilo do Frete Grátis (Acima do preço) *\/\n  .custom-frete-gratis {\n    display: flex;\n    align-items: center;\n    gap: 0.35rem;\n    background-color: transparent !important;\n    color: #1c1c1c !important;\n    font-size: 0.8rem;\n    font-weight: bold;\n    text-transform: uppercase;\n    margin-bottom: 0.5rem;\n  }\n\n  .custom-frete-gratis svg {\n    stroke: currentColor;\n  }\n\n  \/* Estilo do Box de Desconto (Ao lado do preço riscado) *\/\n  .custom-discount-box {\n    display: inline-flex;\n    align-items: center;\n    background-color: #1c1c1c !important;\n    color: #ffffff !important;\n    padding: 0.15rem 0.4rem;\n    \/* margin-left e border-radius removidos *\/\n    font-size: 0.75rem;\n    font-weight: bold;\n    text-transform: uppercase;\n    line-height: 1.2;\n    vertical-align: middle;\n  }\n  \n  \/* Ajuste de segurança *\/\n  compare-at-price {\n    display: inline-flex;\n    align-items: center;\n  }\n<\/style>","text_alignment":"start"}}},"order":["text-with-icons","footer","custom_liquid_eUAy7z"]}